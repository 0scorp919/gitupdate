# ============================================================
# Git Portable Manager — Environment Variables (.env.example)
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file to .env (same directory as git_manager.py)
#   2. Fill in real values
#   3. .env is gitignored — NEVER commit it to git
#
# UA: Скопіюй цей файл у .env та заповни реальними значеннями.
#     .env НЕ комітити у git (вже у .gitignore).
# ============================================================

# --- SECURITY ---
# UA: Пароль AES-256 для шифрування резервних копій Git (7-Zip -p + -mhe=on).
#     ОБОВ'ЯЗКОВО. Якщо порожньо — резервна копія НЕ створюється (ERROR).
# GIT_BACKUP_PASSWORD=your_strong_password_here

# --- VAULTWARDEN (recommended — безпечна альтернатива прямому паролю) ---
# UA: Пароль береться з Vaultwarden замість прямого зберігання у файлі.
#     Якщо BW_HOST задано — GIT_BACKUP_PASSWORD ігнорується.
#     Потребує bw.exe у apps/bin/ (встановлюється через Win+R → bin).
#
# Процес автентифікації:
#   1. bw status → unauthenticated / locked / unlocked
#   2. unauthenticated → bw login (email + пароль + 2FA, до 3 спроб)
#   3. locked          → bw unlock (тільки майстер-пароль, до 3 спроб)
#   4. unlocked        → bw unlock --raw (свіжий session token)
#   5. bw sync --session → синхронізація локального кешу
#   6. bw get item BW_ITEM_NAME --session → пароль
#   7. bw lock → блокування після використання
#
# ⚠️  ВСТАВКА ПАРОЛЯ: тільки Ctrl+V! Права кнопка миші обрізає пароль (UIPI/UAC).
#
# BW_HOST=https://your-vaultwarden-instance.example.com
# BW_EMAIL=your-email@example.com
# BW_METHOD=0
# BW_ITEM_NAME=CAPSULE_GIT_BACKUP_PASSWORD
# BW_SSH_KEY_MAIN_ITEM=Github Oleksii Rovnianskyi (oleksii-rovnianskyi)
# BW_SSH_KEY_SECURITY_ITEM=Github Oleksii Rovnianskyi 0scorp919
#
# BW_METHOD: 0 = Authenticator App (TOTP), 1 = Email 2FA

# --- GITHUB CLI TOKENS ---
# UA: Personal Access Tokens для GitHub CLI (gh.exe).
#     Передаються як змінна середовища GH_TOKEN до процесу gh.exe.
#
# Як створити Fine-grained PAT (мінімальні права):
#   GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
#   Repository permissions: Contents → Read-only, Metadata → Read-only
#
# UA: Основний акаунт GitHub
GH_TOKEN_MAIN=github_pat_your_main_token_here

# UA: Додатковий акаунт GitHub (наприклад security lab)
GH_TOKEN_SECURITY=github_pat_your_secondary_token_here

# --- РЕПОЗИТОРІЇ ДЛЯ СИНХРОНІЗАЦІЇ (git push) ---
# UA: Список репозиторіїв капсули для автоматичного push при запуску з --sync.
#     Формат: SYNC_REPO_XX=name:relative_local_path:account (main|security)
#     Менеджер автоматично додає CAPSULE_ROOT до шляху.
#
# SYNC_REPO_01=project-core:.:main
# SYNC_REPO_02=notes-vault:second-brain:main
# SYNC_REPO_03=app-update:devops/appupdate:security
